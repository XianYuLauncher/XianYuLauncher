<Page
    x:Class="XianYuLauncher.Features.ModLoaderSelector.Views.ModLoaderSelectorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:XianYuLauncher.Models"
    xmlns:helpers="using:XianYuLauncher.Helpers"
    xmlns:core="using:XianYuLauncher.Core.Models"
    xmlns:services="using:XianYuLauncher.Core.Services"
    xmlns:controls="using:XianYuLauncher.Controls"
    xmlns:featureControls="using:XianYuLauncher.Features.ModLoaderSelector.Controls"
    xmlns:shared="using:XianYuLauncher.Shared.Models"
    mc:Ignorable="d"
    HorizontalAlignment="Stretch">

    <Page.Resources>
        <helpers:StringNullOrEmptyToBoolConverter x:Key="StringNullOrEmptyToBoolConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <helpers:InverseBoolConverter x:Key="InverseBoolConverter" />
        <helpers:InverseBoolToOpacityConverter x:Key="InverseBoolToOpacityConverter" />
        <helpers:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter" />
        <helpers:BoolToBrushConverter x:Key="BoolToBrushConverter" />
        <helpers:ModLoaderToIconConverter x:Key="ModLoaderToIconConverter" />
        <helpers:StringEqualsConverter x:Key="StringEqualsConverter" />
        <helpers:PathToImageSourceConverter x:Key="PathToImageSourceConverter" />
        
        <Style x:Key="VersionListViewItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>

        <DataTemplate x:Key="NavigationBreadcrumbItemTemplate" x:DataType="shared:NavigationBreadcrumbItem">
            <TextBlock Text="{x:Bind DisplayText}" />
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="ContentArea">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="100*" MaxWidth="1064" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <!-- 三列居中布局：中间列最大宽度 1064，窄窗口填满，宽窗口内容居中且不被拉得过宽 -->
        <Grid Grid.Column="1" VerticalAlignment="Stretch" Margin="24,0,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <controls:PageHeader
            Grid.Row="0"
            Title="{x:Bind ViewModel.HeaderMetadata.Title, Mode=OneWay}"
            Subtitle="{x:Bind ViewModel.HeaderMetadata.Subtitle, Mode=OneWay}"
            ShowBreadcrumb="{x:Bind ViewModel.HeaderMetadata.ShowBreadcrumb, Mode=OneWay}"
            BreadcrumbItems="{x:Bind ViewModel.HeaderMetadata.BreadcrumbItems, Mode=OneWay}"
            BreadcrumbItemTemplate="{StaticResource NavigationBreadcrumbItemTemplate}"
            BreadcrumbItemClicked="PageHeader_BreadcrumbItemClicked">
            <controls:PageHeader.HeaderSupplementalContent>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock x:Uid="ModLoaderSelectionPage_CurrentVersionText" Text="当前版本:" Style="{StaticResource BodyTextStyle}" Opacity="0.7" VerticalAlignment="Center" Margin="0,0,0,2" />

                    <DropDownButton Padding="8,4" VerticalAlignment="Center" CornerRadius="4" BorderThickness="0" Background="Transparent" Margin="-8,0,0,0">
                        <DropDownButton.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Image
                                    Source="{x:Bind ViewModel.SelectedIconPath, Mode=OneWay, Converter={StaticResource PathToImageSourceConverter}}"
                                    Width="16" Height="16" Stretch="UniformToFill" VerticalAlignment="Center" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.SelectedVersionDisplayText, Mode=OneWay}"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    VerticalAlignment="Center" Margin="0,0,4,0" />
                            </StackPanel>
                        </DropDownButton.Content>
                        <DropDownButton.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <controls:VersionIconPickerFlyoutContent
                                    AvailableIcons="{x:Bind ViewModel.AvailableIcons, Mode=OneWay}"
                                    BuiltInIconSelected="VersionIconPicker_BuiltInIconSelected"
                                    CustomIconRequested="VersionIconPicker_CustomIconRequested" />
                            </Flyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </StackPanel>
            </controls:PageHeader.HeaderSupplementalContent>
        </controls:PageHeader>

        <featureControls:ModLoaderSelectorContentView
            Grid.Row="1"
            Grid.RowSpan="3"
            ViewModel="{x:Bind ViewModel}" />
        </Grid>
    </Grid>
</Page>