<Page
    x:Class="XianYuLauncher.Features.Shell.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:XianYuLauncher.Helpers"
    xmlns:controls="using:XianYuLauncher.Controls"
    xmlns:shared="using:XianYuLauncher.Shared.Models"
    xmlns:viewModels="using:XianYuLauncher.Features.Shell.Models"
    xmlns:media="using:CommunityToolkit.WinUI.Media"
    Loaded="OnLoaded">

    <Page.Resources>
        <ResourceDictionary>
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <helpers:PathToImageSourceConverter x:Key="PathToImageSourceConverter" />
            <Style x:Key="ProminentBreadcrumbTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <DataTemplate x:Key="InteractiveBreadcrumbItemTemplate" x:DataType="shared:NavigationBreadcrumbItem">
                <Grid>
                    <TextBlock Text="{x:Bind DisplayText, Mode=OneWay}"
                               Style="{StaticResource ProminentBreadcrumbTextStyle}"
                               Visibility="{x:Bind CanShowInlineAction, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                    <DropDownButton Padding="12,8"
                                    FontSize="28"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    CornerRadius="4"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Visibility="{x:Bind CanShowInlineAction, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <DropDownButton.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Image Source="{x:Bind IconPath, Mode=OneWay, Converter={StaticResource PathToImageSourceConverter}}"
                                       Width="20"
                                       Height="20"
                                       Stretch="UniformToFill"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind DisplayText, Mode=OneWay}"
                                           Style="{StaticResource ProminentBreadcrumbTextStyle}"
                                           Margin="0,0,4,0" />
                            </StackPanel>
                        </DropDownButton.Content>
                        <DropDownButton.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <controls:VersionIconPickerFlyoutContent
                                    AvailableIcons="{x:Bind AvailableIcons, Mode=OneWay}"
                                    BuiltInIconSelected="VersionIconPicker_BuiltInIconSelected"
                                    CustomIconRequested="VersionIconPicker_CustomIconRequested" />
                            </Flyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </Grid>
            </DataTemplate>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="MotionOverlayColor">#CCFFFFFF</Color>
                    <x:Double x:Key="MotionOverlayOpacity">0.5</x:Double>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="MotionOverlayColor">#FF000000</Color>
                    <x:Double x:Key="MotionOverlayOpacity">0.3</x:Double>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="RootGrid" AllowDrop="True" DragOver="Shell_DragOver" Drop="Shell_Drop">
        <!-- 动态光效背景 (ZIndex -2: 最底层) - 默认隐藏 -->
        <controls:MotionBackgroundControl x:Name="MotionBg" Canvas.ZIndex="-2" Visibility="Collapsed" />
        
        <!-- 亚克力磨砂层 (ZIndex -1.5) - 默认隐藏 -->
        <Rectangle x:Name="AcrylicOverlay" 
                   Canvas.ZIndex="-1" 
                   IsHitTestVisible="False"
                   Visibility="Collapsed">
            <Rectangle.Fill>
                <AcrylicBrush TintColor="{ThemeResource MotionOverlayColor}" 
                              TintOpacity="{ThemeResource MotionOverlayOpacity}" 
                              FallbackColor="{ThemeResource MotionOverlayColor}"/>
            </Rectangle.Fill>
        </Rectangle>

        <!-- 自定义背景图片层 -->
                <Image x:Name="BackgroundImage"
               Stretch="UniformToFill"
               Visibility="Collapsed"
               Canvas.ZIndex="-1" />
        
        <!-- 背景图片模糊层 -->
        <Border x:Name="BackgroundBlurOverlay"
                Canvas.ZIndex="-1"
                Visibility="Collapsed">
            <Border.Background>
                <media:BackdropBlurBrush x:Name="BackgroundBlurBrush" Amount="5" />
            </Border.Background>
        </Border>
        <TitleBar x:Name="AppTitleBar"
                  Canvas.ZIndex="1"
                  Height="48"
                  VerticalAlignment="Top"
                  Title="XianYu Launcher">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/WindowIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>
        <NavigationView
            x:Name="NavigationViewControl"
            Canvas.ZIndex="0"
            Background="Transparent"
            IsBackButtonVisible="Visible"
            IsBackEnabled="{x:Bind ViewModel.IsBackEnabled, Mode=OneWay}"
            AlwaysShowHeader="False"
            SelectedItem="{x:Bind ViewModel.Selected, Mode=OneWay}"
            IsSettingsVisible="True"
            ExpandedModeThresholdWidth="1280"
            DisplayModeChanged="NavigationViewControl_DisplayModeChanged">
            <NavigationView.MenuItems>
                <!--
                Update item titles by updating <x:Uid>.Content entries in Strings/en-us/Resources.resw.
                https://docs.microsoft.com/windows/uwp/app-resources/localize-strings-ui-manifest#refer-to-a-string-resource-identifier-from-xaml
            
                Update item icons by updating FontIcon.Glyph properties.
                https://docs.microsoft.com/windows/apps/design/style/segoe-fluent-icons-font#icon-list
                -->
                <NavigationViewItem x:Uid="Shell_启动" helpers:NavigationHelper.NavigateTo="XianYuLauncher.Features.Launch.ViewModels.LaunchViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xe768;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_资源下载" helpers:NavigationHelper.NavigateTo="XianYuLauncher.Features.ResourceDownload.ViewModels.ResourceDownloadViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE896;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_版本列表" helpers:NavigationHelper.NavigateTo="XianYuLauncher.Features.VersionList.ViewModels.VersionListViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xe838;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_角色" helpers:NavigationHelper.NavigateTo="XianYuLauncher.Features.Accounts.ViewModels.CharacterViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xe77b;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_联机" helpers:NavigationHelper.NavigateTo="XianYuLauncher.Features.Multiplayer.ViewModels.MultiplayerViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE945;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_LauncherAI"
                                    helpers:NavigationHelper.NavigateTo="XianYuLauncher.Features.ErrorAnalysis.ViewModels.LauncherAIViewModel"
                                    Visibility="{x:Bind ViewModel.LauncherAINavigationVisibility, Mode=OneWay}">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xF4A5;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Uid="Shell_下载队列" helpers:NavigationHelper.NavigateTo="XianYuLauncher.Features.DownloadQueue.ViewModels.DownloadQueueViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE118;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            <Grid Margin="{StaticResource NavigationViewPageContentMargin}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <controls:PageHeader
                    x:Name="SharedPageHeader"
                    Grid.Row="0"
                    Title="{x:Bind ViewModel.CurrentHeaderMetadata.Title, Mode=OneWay}"
                    Subtitle="{x:Bind ViewModel.CurrentHeaderMetadata.Subtitle, Mode=OneWay}"
                    ShowBreadcrumb="{x:Bind ViewModel.CurrentHeaderMetadata.ShowBreadcrumb, Mode=OneWay}"
                    ShowPrimaryHeading="{x:Bind ViewModel.CurrentHeaderHostConfiguration.ShowPrimaryHeading, Mode=OneWay}"
                    BreadcrumbFontSize="{x:Bind ViewModel.CurrentHeaderHostConfiguration.BreadcrumbFontSize, Mode=OneWay}"
                    BreadcrumbMargin="{x:Bind ViewModel.CurrentHeaderHostConfiguration.BreadcrumbMargin, Mode=OneWay}"
                    BreadcrumbItems="{x:Bind ViewModel.CurrentHeaderMetadata.BreadcrumbItems, Mode=OneWay}"
                    BreadcrumbItemTemplate="{x:Bind CurrentHeaderBreadcrumbItemTemplate, Mode=OneWay}"
                    HeaderSupplementalContent="{x:Bind CurrentHeaderSupplementalContent, Mode=OneWay}"
                    TrailingActions="{x:Bind CurrentHeaderTrailingActions, Mode=OneWay}"
                    BreadcrumbItemClicked="SharedPageHeader_BreadcrumbItemClicked"
                    Visibility="{x:Bind ViewModel.IsShellHeaderVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Frame x:Name="NavigationFrame" Grid.Row="1">
                    <Frame.ContentTransitions>
                        <TransitionCollection>
                            <NavigationThemeTransition />
                        </TransitionCollection>
                    </Frame.ContentTransitions>
                </Frame>
            </Grid>
        </NavigationView>

        <!-- 下载 TeachingTip：TopRight 时右缘与锚点右对齐，底缘在锚点上方，故「窗缘→气泡底」≈ Padding.Bottom+锚点+PlacementMargin.Top，「窗缘→气泡右」≈ Padding.Right。右略加大使与底观感对齐。 -->
        <Border HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False"
                Background="Transparent"
                Padding="0,0,56,20"
                Canvas.ZIndex="2">
            <Grid>
                <Button x:Name="ShellDownloadTipAnchor"
                        Width="1"
                        Height="1"
                        Opacity="0"
                        IsHitTestVisible="False"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0" />
                <ItemsControl ItemsSource="{x:Bind ViewModel.DownloadTeachingTips, Mode=OneWay}"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:ShellDownloadTipItem">
                            <TeachingTip Title="{x:Bind Title, Mode=OneWay}"
                                         IsOpen="{x:Bind IsOpen, Mode=OneWay}"
                                         PreferredPlacement="TopRight"
                                         Padding="12,10,12,12"
                                         TailVisibility="Collapsed"
                                         IsLightDismissEnabled="False"
                                         Loaded="DownloadTeachingTip_Loaded"
                                         CloseButtonClick="DownloadTeachingTip_CloseButtonClick">
                                <TeachingTip.Content>
                                    <StackPanel Spacing="8" MinWidth="280">
                                        <ProgressBar Value="{x:Bind Progress, Mode=OneWay}"
                                                     Maximum="100"
                                                     Height="8" />
                                        <TextBlock Text="{x:Bind StatusMessage, Mode=OneWay}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </TeachingTip.Content>
                            </TeachingTip>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</Page>
