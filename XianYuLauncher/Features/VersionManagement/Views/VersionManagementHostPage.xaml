<Page
    x:Class="XianYuLauncher.Features.VersionManagement.Views.VersionManagementHostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mediaAnimation="using:Microsoft.UI.Xaml.Media.Animation"
    mc:Ignorable="d">

    <Grid x:Name="ContentArea"
          mediaAnimation:EntranceNavigationTransitionInfo.IsTargetElement="True">
        <Frame x:Name="VersionManagementInnerContentFrame"
               Background="Transparent"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch">
            <Frame.ContentTransitions>
                <TransitionCollection>
                    <NavigationThemeTransition />
                </TransitionCollection>
            </Frame.ContentTransitions>
        </Frame>
    </Grid>
</Page>
