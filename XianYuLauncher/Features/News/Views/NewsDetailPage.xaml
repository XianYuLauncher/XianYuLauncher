<Page
    x:Class="XianYuLauncher.Features.News.Views.NewsDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:CommunityToolkit.WinUI.Media"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="40,36,40,0" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100*" MaxWidth="1064" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                x:Name="BackButton"
                Click="BackButton_Click"
                PointerEntered="BackButton_PointerEntered"
                PointerExited="BackButton_PointerExited"
                Style="{StaticResource SubtleButtonStyle}"
                Padding="4"
                CornerRadius="4"
                Margin="0,0,12,0"
                VerticalAlignment="Center">
                <AnimatedIcon x:Name="BackAnimatedIcon" Width="24" Height="24">
                    <AnimatedIcon.Source>
                        <animatedvisuals:AnimatedBackVisualSource/>
                    </AnimatedIcon.Source>
                    <AnimatedIcon.FallbackIconSource>
                        <SymbolIconSource Symbol="Back"/>
                    </AnimatedIcon.FallbackIconSource>
                </AnimatedIcon>
            </Button>

            <TextBlock
                Grid.Column="1"
                x:Uid="NewsDetailPage_Title"
                Text="新闻详情"
                Style="{StaticResource TitleTextBlockStyle}"
                FontWeight="SemiBold"
                VerticalAlignment="Center" />
            </Grid>
        </Grid>

        <ScrollViewer
            Grid.Row="1"
            Padding="40,24,40,24"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="100*" MaxWidth="1064" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Spacing="20" HorizontalAlignment="Stretch">
                <Border
                    x:Name="ImageBorder"
                    CornerRadius="8"
                    Height="400"
                    Visibility="Collapsed">
                    <Grid>
                        <Image
                            x:Name="NewsImageBg"
                            Stretch="UniformToFill"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                        <Border x:Name="BlurBorder" Visibility="Collapsed">
                            <Border.Background>
                                <media:BackdropBlurBrush Amount="10" />
                            </Border.Background>
                        </Border>

                        <Rectangle Fill="{ThemeResource SolidBackgroundFillColorBaseBrush}" Opacity="0.05"/>

                        <Border
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="32"
                            CornerRadius="8"
                            Translation="0,0,32">
                            <Border.Shadow>
                                <ThemeShadow />
                            </Border.Shadow>

                            <Image
                                x:Name="NewsImage"
                                Stretch="Uniform" />
                        </Border>
                    </Grid>
                </Border>

                <TextBlock
                    x:Name="TitleTextBlock"
                    Style="{StaticResource TitleLargeTextBlockStyle}"
                    FontWeight="Bold"
                    TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="4"
                        Padding="8,4">
                        <TextBlock
                            x:Name="TypeTextBlock"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                    </Border>
                    <Border
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        CornerRadius="4"
                        Padding="8,4">
                        <TextBlock
                            x:Name="VersionTextBlock"
                            Style="{StaticResource CaptionTextBlockStyle}" />
                    </Border>
                    <TextBlock
                        x:Name="DateTextBlock"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Center" />
                </StackPanel>

                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.5" />

                <TextBlock
                    x:Name="ShortTextBlock"
                    Style="{StaticResource BodyTextBlockStyle}"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <StackPanel
                    x:Name="LoadingPanel"
                    Orientation="Horizontal"
                    Spacing="8"
                    Visibility="Collapsed">
                    <ProgressRing IsActive="True" Width="16" Height="16" />
                    <TextBlock x:Uid="NewsDetailPage_Loading" Text="加载详细内容..." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <Border
                    x:Name="ContentBorder"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Visibility="Collapsed">
                    <StackPanel Spacing="12">
                        <TextBlock
                            x:Uid="NewsDetailPage_UpdateContent"
                            Text="更新内容"
                            Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock
                            x:Name="ContentTextBlock"
                            Style="{StaticResource BodyTextBlockStyle}"
                            TextWrapping="Wrap"
                            IsTextSelectionEnabled="True" />
                    </StackPanel>
                </Border>

                <TextBlock
                    x:Uid="NewsDetailPage_FullChangelogHint"
                    Text="完整更新日志请访问 Minecraft 官网"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>