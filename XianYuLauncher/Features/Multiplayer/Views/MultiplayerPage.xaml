<Page
    x:Class="XianYuLauncher.Features.Multiplayer.Views.MultiplayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:XianYuLauncher.Helpers"
    xmlns:localControls="using:XianYuLauncher.Controls"
    xmlns:mediaAnimation="using:Microsoft.UI.Xaml.Media.Animation"
    xmlns:shared="using:XianYuLauncher.Shared.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />

        <Style x:Key="ProminentBreadcrumbTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <DataTemplate x:Key="HostedDetailReadOnlyBreadcrumbItemTemplate" x:DataType="shared:NavigationBreadcrumbItem">
            <Grid>
                <TextBlock Text="{x:Bind DisplayText, Mode=OneWay}"
                           Style="{StaticResource ProminentBreadcrumbTextStyle}"
                           Visibility="{x:Bind IsCurrent, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                <Border Padding="0,8,0,8"
                        Visibility="{x:Bind IsCurrent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{x:Bind DisplayText, Mode=OneWay}"
                               Style="{StaticResource ProminentBreadcrumbTextStyle}" />
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="ContentArea"
          mediaAnimation:EntranceNavigationTransitionInfo.IsTargetElement="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <localControls:PageHeader
            x:Name="MultiplayerPageHeader"
            Grid.Row="0"
            BreadcrumbItemClicked="PageHeader_BreadcrumbItemClicked" />

        <Grid x:Name="MultiplayerInnerContentHost"
              Grid.Row="1"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Frame x:Name="MultiplayerInnerContentFrame"
                   Background="Transparent"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </Grid>
    </Grid>
</Page>