<Page
    x:Class="XianYuLauncher.Features.Multiplayer.Views.MultiplayerRootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="ContentArea" Padding="{StaticResource PageScrollViewerPadding}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="100*" MaxWidth="1064" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="1" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <InfoBar
                Grid.Row="0"
                IsOpen="True"
                IsClosable="True"
                Margin="0,0,0,30"
                x:Uid="MultiplayerPage_Warning"
                Title="警告"
                Message="陶瓦联机是第三方开源自由软件，您在使用过程中所遇到的问题请通过其官方渠道进行反馈。陶瓦联机基于 P2P 点对点技术实现，联机成功后房间内用户之间将直接建立网络连接，无任何公共中转节点、不通过第三方服务器转发流量，最终联机体验取决于参与联机者的网络环境。您在使用多人联机功能的全过程中，必须严格遵守您所在国家与地区的全部法律法规，不得用于任何违法违规及经营性活动。" />

            <Grid
                x:Name="ActionCardsGrid"
                Grid.Row="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Margin="0,10,0,0"
                MaxWidth="648">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Command="{x:Bind ViewModel.HostGameCommand}"
                    Style="{StaticResource TextBlockButtonStyle}"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
                    <Grid MaxWidth="300" MinHeight="200" HorizontalAlignment="Stretch">
                        <Border
                            Background="{ThemeResource CardBackgroundFillColorDefault}"
                            BorderBrush="{ThemeResource CardStrokeColorDefault}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="24">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                                <FontIcon
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    Glyph="&#xe770;"
                                    FontSize="48"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock
                                    x:Uid="MultiplayerPage_HostCardTitle"
                                    Text="我想当房主"
                                    Style="{ThemeResource SubtitleTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorPrimary}"
                                    HorizontalAlignment="Center"/>
                                <TextBlock
                                    x:Uid="MultiplayerPage_HostCardDescription"
                                    Text="创建一个新的游戏房间，邀请其他玩家加入"
                                    Style="{ThemeResource BodyTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorPrimary}"
                                    TextWrapping="WrapWholeWords"
                                    TextAlignment="Center"
                                    Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Button>

                <Button
                    Grid.Column="2"
                    Command="{x:Bind ViewModel.JoinGameCommand}"
                    Style="{StaticResource TextBlockButtonStyle}"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
                    <Grid MaxWidth="300" MinHeight="200" HorizontalAlignment="Stretch">
                        <Border
                            Background="{ThemeResource CardBackgroundFillColorDefault}"
                            BorderBrush="{ThemeResource CardStrokeColorDefault}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="24">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                                <FontIcon
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    Glyph="&#xe718;"
                                    FontSize="48"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock
                                    x:Uid="MultiplayerPage_GuestCardTitle"
                                    Text="我想当房客"
                                    Style="{ThemeResource SubtitleTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorPrimary}"
                                    HorizontalAlignment="Center"/>
                                <TextBlock
                                    x:Uid="MultiplayerPage_GuestCardDescription"
                                    Text="加入其他玩家创建的游戏房间"
                                    Style="{ThemeResource BodyTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorPrimary}"
                                    TextWrapping="WrapWholeWords"
                                    TextAlignment="Center"
                                    Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Page>