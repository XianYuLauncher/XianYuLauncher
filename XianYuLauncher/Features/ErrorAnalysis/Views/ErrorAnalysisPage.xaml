<Page
    x:Class="XianYuLauncher.Features.ErrorAnalysis.Views.ErrorAnalysisPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:XianYuLauncher.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mediaAnimation="using:Microsoft.UI.Xaml.Media.Animation"
    mc:Ignorable="d">

    <Grid x:Name="ContentArea"
          mediaAnimation:EntranceNavigationTransitionInfo.IsTargetElement="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:PageHeader
            x:Name="ErrorAnalysisPageHeader"
            Grid.Row="0"
            Title="{x:Bind ViewModel.HeaderMetadata.Title, Mode=OneWay}"
            Subtitle="{x:Bind ViewModel.HeaderMetadata.Subtitle, Mode=OneWay}"
            ShowBreadcrumb="{x:Bind ViewModel.HeaderMetadata.ShowBreadcrumb, Mode=OneWay}"
            BreadcrumbItems="{x:Bind ViewModel.HeaderMetadata.BreadcrumbItems, Mode=OneWay}"
            BreadcrumbItemClicked="PageHeader_BreadcrumbItemClicked" />

        <Grid Grid.Row="1"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Padding="{StaticResource PageScrollViewerPadding}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100*" MaxWidth="1064" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="1" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16" Spacing="8" VerticalAlignment="Center">
                    <Button x:Uid="ErrorAnalysis_ExportLogButton" Content="导出日志" Command="{x:Bind ViewModel.ExportErrorLogsCommand}" Width="120" Height="36" />
                    <Button x:Uid="ErrorAnalysis_CopyLogButton" Content="复制日志" Command="{x:Bind ViewModel.CopyLogsCommand}" Width="120" Height="36" />
                    <Button x:Uid="ErrorAnalysis_ContactAuthorButton" Content="联系作者" Command="{x:Bind ViewModel.JoinQQGroupCommand}" Width="120" Height="36" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Uid="ErrorAnalysis_LogDetails" Text="实时日志详情" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <Border Grid.Row="1"
                            Background="{ThemeResource TextControlBackground}"
                            BorderBrush="{ThemeResource TextControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ListView ItemsSource="{x:Bind ViewModel.LogLines, Mode=OneWay}"
                                  x:Name="LogListView"
                                  SelectionMode="Extended"
                                  IsItemClickEnabled="False"
                                  Background="Transparent"
                                  Padding="8">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock Text="{x:Bind}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,2" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Border>
                </Grid>

                <controls:LauncherAIPanel
                    Grid.Row="2"
                    Margin="0,16,0,16"
                    x:Uid="ErrorAnalysis_AiPanel"
                    ViewModel="{x:Bind ViewModel}"
                    MessagesMaxHeight="300"
                    ShowEmptyPlaceholder="True"
                    EmptyPlaceholderText="{x:Bind ViewModel.NoErrorInfoText, Mode=OneWay}"
                    PopOutRequested="PopOutChat_Click" />
            </Grid>
        </Grid>
    </Grid>
</Page>