<Page
    x:Class="XianYuLauncher.Features.ErrorAnalysis.Views.LauncherAIPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:XianYuLauncher.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mediaAnimation="using:Microsoft.UI.Xaml.Media.Animation"
    mc:Ignorable="d">

    <Grid x:Name="ContentArea"
          Background="Transparent"
          mediaAnimation:EntranceNavigationTransitionInfo.IsTargetElement="True">
        <Grid Margin="24,0,24,24" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100*" MaxWidth="1064" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:LauncherAIWorkspacePanel
                Grid.Column="1"
                Margin="0,0,0,20"
                ViewModel="{x:Bind ViewModel}" />
        </Grid>
    </Grid>
</Page>