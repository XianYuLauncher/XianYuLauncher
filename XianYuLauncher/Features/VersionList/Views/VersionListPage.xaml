<Page
    x:Class="XianYuLauncher.Features.VersionList.Views.VersionListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:XianYuLauncher.Helpers"
    xmlns:localControls="using:XianYuLauncher.Controls"
    xmlns:mediaAnimation="using:Microsoft.UI.Xaml.Media.Animation"
    xmlns:shared="using:XianYuLauncher.Shared.Models"
    NavigationCacheMode="Required"
    mc:Ignorable="d">
    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:BoolNegationConverter x:Key="BoolNegationConverter" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />

        <Style x:Key="ProminentBreadcrumbTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <DataTemplate x:Key="HostedDetailReadOnlyBreadcrumbItemTemplate" x:DataType="shared:NavigationBreadcrumbItem">
            <Grid>
                <TextBlock Text="{x:Bind DisplayText, Mode=OneWay}"
                           Style="{StaticResource ProminentBreadcrumbTextStyle}"
                           Visibility="{x:Bind IsCurrent, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                <Border Padding="0,8,0,8"
                        Visibility="{x:Bind IsCurrent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{x:Bind DisplayText, Mode=OneWay}"
                               Style="{StaticResource ProminentBreadcrumbTextStyle}" />
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="ContentArea" mediaAnimation:EntranceNavigationTransitionInfo.IsTargetElement="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <localControls:PageHeader
            x:Name="VersionListPageHeader"
            Grid.Row="0"
            BreadcrumbItemClicked="PageHeader_BreadcrumbItemClicked">
            <localControls:PageHeader.HeaderSupplementalContent>
                <Grid x:Name="RootHeaderSupplementalContent" Margin="0,0,0,4" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <AutoSuggestBox
                        x:Uid="VersionListPage_SearchBox"
                        QueryIcon="Find"
                        PlaceholderText="搜索版本..."
                        Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        IsEnabled="{Binding IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                        VerticalAlignment="Center" />

                    <ComboBox
                        Grid.Column="1"
                        x:Uid="VersionListPage_LoaderFilter"
                        Margin="8,0,0,0"
                        SelectedValue="{Binding SelectedLoaderFilter, Mode=TwoWay}"
                        SelectedValuePath="Tag"
                        IsEnabled="{Binding IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                        VerticalAlignment="Center">
                        <ComboBoxItem x:Uid="VersionListPage_AllLoaders" Content="全部" Tag="all" IsSelected="True" />
                        <ComboBoxItem Content="Release" Tag="Release" />
                        <ComboBoxItem Content="Forge" Tag="Forge" />
                        <ComboBoxItem Content="Fabric" Tag="Fabric" />
                        <ComboBoxItem Content="NeoForge" Tag="NeoForge" />
                        <ComboBoxItem Content="Quilt" Tag="Quilt" />
                        <ComboBoxItem Content="OptiFine" Tag="OptiFine" />
                        <ComboBoxItem Content="LiteLoader" Tag="LiteLoader" />
                        <ComboBoxItem Content="LegacyFabric" Tag="LegacyFabric" />
                    </ComboBox>

                    <Button
                        Grid.Column="2"
                        x:Uid="VersionListPage_ImportModpackButton"
                        Content="导入整合包"
                        Command="{Binding ImportModpackCommand}"
                        IsEnabled="{Binding IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                        Style="{StaticResource DefaultButtonStyle}"
                        HorizontalAlignment="Right"
                        Margin="8,0,8,0" />

                    <Button
                        Grid.Column="3"
                        x:Uid="VersionListPage_RefreshButton"
                        Command="{Binding LoadVersionsCommand}"
                        IsEnabled="{Binding IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                        Style="{StaticResource DefaultButtonStyle}"
                        HorizontalAlignment="Right" />
                </Grid>
            </localControls:PageHeader.HeaderSupplementalContent>

            <localControls:PageHeader.TrailingActions>
                <Button
                    x:Name="OpenCurrentFolderButton"
                    ToolTipService.ToolTip="打开文件夹"
                    VerticalAlignment="Center"
                    Style="{StaticResource DefaultButtonStyle}"
                    Padding="8"
                    Height="32"
                    Visibility="Collapsed">
                    <FontIcon Glyph="&#xE838;" FontSize="16" />
                </Button>
            </localControls:PageHeader.TrailingActions>
        </localControls:PageHeader>

        <Grid x:Name="VersionListInnerContentHost"
              Grid.Row="1"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Padding="{StaticResource PageScrollViewerPadding}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100*" MaxWidth="1064" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Frame x:Name="VersionListInnerContentFrame"
                   Grid.Column="1"
                   Background="Transparent"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </Grid>
    </Grid>
</Page>