<UserControl
    x:Class="XianYuLauncher.Features.Dialogs.Views.DownloadProgressDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="500"
    Height="250">

    <StackPanel Spacing="20" Padding="20" VerticalAlignment="Center">
        <TextBlock Text="正在下载更新" FontWeight="Bold" FontSize="18" TextAlignment="Center" />

        <StackPanel Spacing="12">
            <ProgressBar Value="{x:Bind ViewModel.DownloadProgress, Mode=OneWay}"
                         Minimum="0"
                         Maximum="100"
                         Height="12"
                         CornerRadius="6"
                         Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}"
                         Foreground="{ThemeResource SystemAccentColor}" />

            <TextBlock Text="{x:Bind ViewModel.DownloadStatusText, Mode=OneWay}" TextAlignment="Center" FontSize="14" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                <TextBlock Text="{x:Bind ViewModel.DownloadSpeedText, Mode=OneWay}" FontSize="12" Foreground="#666666" />
                <TextBlock Text="{x:Bind ViewModel.EstimatedTimeText, Mode=OneWay}" FontSize="12" Foreground="#666666" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>