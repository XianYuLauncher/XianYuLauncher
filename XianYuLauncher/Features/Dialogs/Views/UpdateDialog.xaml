<UserControl
    x:Class="XianYuLauncher.Features.Dialogs.Views.UpdateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="500">

    <StackPanel Spacing="12" Padding="20">
        <TextBlock Text="{x:Bind ViewModel.UpdateInfo.version, Mode=OneWay}" Style="{ThemeResource TitleTextBlockStyle}" />
        <TextBlock Text="新版本带来了以下更新：" />

        <ScrollViewer MaxHeight="200" BorderBrush="Transparent" BorderThickness="0" Padding="0">
            <TextBlock Text="{x:Bind ViewModel.ChangelogText}"
                       TextWrapping="Wrap"
                       LineHeight="24" />
        </ScrollViewer>

        <InfoBar Severity="Warning"
                 Title="重要更新"
                 Message="这是一个重要更新，建议立即安装"
                 IsOpen="{x:Bind ViewModel.UpdateInfo.important_update, Mode=OneWay}"
                 IsClosable="False"
                 HorizontalAlignment="Stretch" />

        <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.IsDownloading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressBar Value="{x:Bind ViewModel.DownloadProgress, Mode=OneWay}"
                         Minimum="0"
                         Maximum="100"
                         Height="8"
                         CornerRadius="4"
                         Background="#E0E0E0"
                         Foreground="#0078D7" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                <TextBlock Text="{x:Bind ViewModel.DownloadStatusText, Mode=OneWay}" FontSize="12" />
                <TextBlock Text="{x:Bind ViewModel.DownloadSpeedText, Mode=OneWay}" FontSize="12" />
                <TextBlock Text="{x:Bind ViewModel.EstimatedTimeText, Mode=OneWay}" FontSize="12" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>