<Page
    x:Class="XianYuLauncher.Views.NewsListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:services="using:XianYuLauncher.Services"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    mc:Ignorable="d">

    <Grid Padding="40,36,40,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 - 居中块(最大1064) + 块内居左 -->
        <Grid Grid.Row="0" Margin="0,0,0,24" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100*" MaxWidth="1064" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <Button 
                Grid.Column="0"
                x:Name="BackButton"
                Style="{StaticResource SubtleButtonStyle}"
                Click="BackButton_Click"
                PointerEntered="BackButton_PointerEntered"
                PointerExited="BackButton_PointerExited"
                Padding="4"
                CornerRadius="4"
                Margin="0,0,12,0"
                VerticalAlignment="Center">
                <AnimatedIcon x:Name="BackAnimatedIcon" Width="24" Height="24">
                    <AnimatedIcon.Source>
                        <animatedvisuals:AnimatedBackVisualSource/>
                    </AnimatedIcon.Source>
                    <AnimatedIcon.FallbackIconSource>
                        <SymbolIconSource Symbol="Back"/>
                    </AnimatedIcon.FallbackIconSource>
                </AnimatedIcon>
            </Button>
            
            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                <TextBlock 
                    x:Uid="NewsListPage_Title"
                    Text="新闻与公告" 
                    Style="{StaticResource TitleTextBlockStyle}" 
                    FontWeight="SemiBold" />
                <TextBlock 
                    x:Uid="NewsListPage_Subtitle"
                    Text="Minecraft Java 版更新动态" 
                    Style="{StaticResource CaptionTextBlockStyle}" 
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            
            <Button 
                Grid.Column="2"
                x:Name="RefreshButton"
                x:Uid="NewsListPage_RefreshButton"
                Click="RefreshButton_Click"
                Style="{StaticResource SubtleButtonStyle}"
                Padding="8"
                CornerRadius="4"
                ToolTipService.ToolTip="刷新">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72C;" FontSize="14" />
            </Button>
            </Grid>
        </Grid>

        <!-- 筛选栏 - 居中块(最大1064) + 块内居左 -->
        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100*" MaxWidth="1064" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
            <ComboBox
                x:Name="SourceFilterComboBox"
                SelectionChanged="SourceFilterComboBox_SelectionChanged">
                <ComboBoxItem Content="全部" Tag="All" IsSelected="True" />
                <ComboBoxItem Content="JavaPatchNote" Tag="JavaPatchNote" />
                <ComboBoxItem Content="News" Tag="News" />
            </ComboBox>
            <ComboBox 
                x:Name="FilterComboBox"
                SelectionChanged="FilterComboBox_SelectionChanged">
                <ComboBoxItem Content="全部" Tag="All" IsSelected="True" />
            </ComboBox>
            </StackPanel>
        </Grid>

        <!-- 内容区 - 居中块(最大1064)，ListView 宽度受限，焦点框与卡片一致 -->
        <Grid Grid.Row="2" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100*" MaxWidth="1064" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1" HorizontalAlignment="Stretch">
                <!-- 加载中 -->
                <StackPanel 
                    x:Name="LoadingPanel"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Visibility="Visible">
                    <ProgressRing IsActive="True" Width="32" Height="32" />
                    <TextBlock x:Uid="NewsListPage_Loading" Text="加载中..." Margin="0,12,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- 错误信息 -->
                <TextBlock 
                    x:Name="ErrorTextBlock"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Visibility="Collapsed" />

                <!-- 新闻列表 -->
                <ListView 
                    x:Name="NewsListView"
                    SelectionMode="None"
                    IsItemClickEnabled="True"
                    ItemClick="NewsItem_Click"
                    Visibility="Collapsed"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="services:MinecraftNewsEntry">
                            <Grid Padding="0,12" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- 类型标识 -->
                            <Border 
                                Grid.Column="0"
                                Width="4"
                                CornerRadius="2"
                                VerticalAlignment="Stretch"
                                Background="{ThemeResource AccentFillColorDefaultBrush}" />
                            
                            <!-- 内容 -->
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock 
                                    Text="{x:Bind Title}"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="1" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border 
                                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="4"
                                        Padding="6,2">
                                        <TextBlock 
                                            Text="{x:Bind Version}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Border>
                                    <TextBlock 
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                        <Run Text="{x:Bind Date, Converter={StaticResource DateTimeToStringConverter}}" />
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- 箭头 -->
                            <FontIcon 
                                Grid.Column="2"
                                FontFamily="{StaticResource SymbolThemeFontFamily}" 
                                Glyph="&#xE76C;" 
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                VerticalAlignment="Center" />
                        </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                            <Setter Property="Padding" Value="12,0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <TeachingTip
                    x:Name="ActivityNewsTeachingTip"
                    Target="{Binding ElementName=NewsListView}"
                    Title="{x:Bind ViewModel.NewsTeachingTipTitle, Mode=OneWay}"
                    IsOpen="{x:Bind ViewModel.IsNewsTeachingTipOpen, Mode=TwoWay}"
                    PreferredPlacement="BottomRight"
                    IsLightDismissEnabled="True"
                    CloseButtonClick="ActivityNewsTeachingTip_CloseButtonClick">
                    <TeachingTip.Content>
                        <StackPanel Spacing="10" MinWidth="320">
                            <Border
                                Visibility="{x:Bind ViewModel.IsNewsTeachingTipImageVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                <Image
                                    Source="{x:Bind ViewModel.NewsTeachingTipImageSource, Mode=OneWay}"
                                    Height="140"
                                    Stretch="UniformToFill" />
                            </Border>
                            <TextBlock
                                Text="{x:Bind ViewModel.NewsTeachingTipSummary, Mode=OneWay}"
                                TextWrapping="Wrap"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <HyperlinkButton
                                Content="在浏览器中查看详情"
                                Command="{x:Bind ViewModel.OpenNewsTeachingTipLinkCommand}"
                                HorizontalAlignment="Left">
                                <HyperlinkButton.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding}" />
                                            <FontIcon
                                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                Glyph="&#xE8A7;"
                                                FontSize="12"
                                                VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </HyperlinkButton.ContentTemplate>
                            </HyperlinkButton>
                        </StackPanel>
                    </TeachingTip.Content>
                </TeachingTip>
            </Grid>
        </Grid>
    </Grid>
</Page>
