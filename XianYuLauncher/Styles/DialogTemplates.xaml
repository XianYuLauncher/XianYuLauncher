<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:XianYuLauncher.Helpers">

    <DataTemplate x:Key="ProfileSelectionItemTemplate">
        <StackPanel Orientation="Horizontal" Padding="10">
            <Border CornerRadius="4" Width="40" Height="40" Margin="0,0,12,0" Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Image Source="{Binding Avatar}" Stretch="Fill" />
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Id}" FontSize="12" Opacity="0.6" />
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="UpdatableResourceSelectionItemTemplate">
        <Grid Margin="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="0" />

            <Border Grid.Column="1" CornerRadius="4" Width="32" Height="32" Background="{ThemeResource LayerFillColorDefaultBrush}" HorizontalAlignment="Left">
                <Grid>
                    <FontIcon Glyph="{Binding FallbackIconGlyph}" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="{Binding HasIconSource, Converter={StaticResource BoolToVisibilityInverseConverter}}" />
                    <Image Source="{Binding IconSource}" Stretch="UniformToFill" Visibility="{Binding HasIconSource, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </Border>

            <StackPanel Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding DisplayName}" MaxLines="1" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" />
                <Grid ColumnSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding ResourceType}" MaxLines="1" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Grid.Column="1" Text="·" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Grid.Column="2" Text="{Binding CurrentVersion}" ToolTipService.ToolTip="{Binding CurrentVersion}" MaxWidth="150" MaxLines="1" TextTrimming="CharacterEllipsis" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <FontIcon Grid.Column="3" Glyph="&#xE709;" FontSize="10" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,0" />
                    <TextBlock Grid.Column="4" Text="{Binding NewVersion}" ToolTipService.ToolTip="{Binding NewVersion}" MaxWidth="150" MaxLines="1" TextTrimming="CharacterEllipsis" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
            </StackPanel>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="MoveResultDialogItemTemplate">
        <Grid Padding="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding ModName}" MaxLines="1" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1" Text="{Binding StatusText}" Margin="12,0,0,0" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>
    </DataTemplate>

</ResourceDictionary>