<UserControl
    x:Class="XianYuLauncher.Controls.LauncherAIWorkspacePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:XianYuLauncher.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="Root">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TabView Grid.Row="0"
                 x:Name="ConversationTabView"
                 SelectionChanged="ConversationTabView_SelectionChanged"
                 AddTabButtonClick="ConversationTabView_AddTabButtonClick"
                 TabCloseRequested="ConversationTabView_TabCloseRequested"
                 IsAddTabButtonVisible="True"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Top"
                 Padding="0"
                 Margin="0,0,0,16">
            <TabView.Resources>
                <Style TargetType="TabViewItem">
                    <Setter Property="MinWidth" Value="140" />
                    <Setter Property="IsClosable" Value="True" />
                </Style>
            </TabView.Resources>
        </TabView>

        <controls:LauncherAIPanel
            x:Name="ChatPanel"
            Grid.Row="1"
            ShowEmptyPlaceholder="True"
            HeaderVisibility="Collapsed"
            PopOutButtonVisibility="Collapsed" />
    </Grid>
</UserControl>