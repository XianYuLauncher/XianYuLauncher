<UserControl
    x:Class="XianYuLauncher.Controls.ErrorAnalysisChatPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ct="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:XianYuLauncher.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:XianYuLauncher.Core.Models"
    xmlns:viewModels="using:XianYuLauncher.ViewModels"
    mc:Ignorable="d"
    x:Name="Root">

    <UserControl.Resources>
        <helpers:PathToImageSourceConverter x:Key="PathToImageSourceConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <ListView
                x:Name="ChatListView"
                ItemsSource="{Binding ViewModel.ChatMessages, ElementName=Root}"
                SelectionMode="None"
                IsItemClickEnabled="False"
                VerticalAlignment="Stretch"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                MaxHeight="{Binding MessagesMaxHeight, ElementName=Root}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:UiChatMessage">
                        <Grid
                            Margin="0,8"
                            Visibility="{x:Bind ShouldShowMessageContainer, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="{x:Bind DisplayRoleText, Mode=OneWay}"
                                    FontWeight="Bold"
                                    FontSize="12"
                                    Opacity="0.6"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Visibility="{x:Bind ShowRoleHeader, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock
                                    Text="{x:Bind Content, Mode=OneWay}"
                                    TextWrapping="Wrap"
                                    FontSize="14"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                    IsTextSelectionEnabled="True"
                                    Visibility="{x:Bind ShowUserText, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <ScrollViewer
                                    HorizontalScrollMode="Auto"
                                    HorizontalScrollBarVisibility="Auto"
                                    VerticalScrollBarVisibility="Disabled"
                                    Visibility="{x:Bind HasImageAttachments, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{x:Bind ImageAttachments, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:ChatImageAttachment">
                                                <StackPanel Width="140" Spacing="6">
                                                    <Border
                                                        Width="140"
                                                        Height="110"
                                                        Tag="{Binding}"
                                                        Tapped="ChatImageCard_Tapped"
                                                        PointerEntered="ChatImageCard_PointerEntered"
                                                        PointerExited="ChatImageCard_PointerExited"
                                                        PointerPressed="ChatImageCard_PointerPressed"
                                                        PointerReleased="ChatImageCard_PointerReleased"
                                                        PointerCanceled="ChatImageCard_PointerExited"
                                                        PointerCaptureLost="ChatImageCard_PointerExited"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Background="{ThemeResource LayerFillColorAltBrush}"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Opacity="1">
                                                        <Image
                                                            Source="{Binding FilePath, Converter={StaticResource PathToImageSourceConverter}}"
                                                            Stretch="UniformToFill" />
                                                    </Border>
                                                    <TextBlock
                                                        Text="{Binding FileName}"
                                                        TextWrapping="NoWrap"
                                                        TextTrimming="CharacterEllipsis"
                                                        FontSize="12"
                                                        Opacity="0.8" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <ct:MarkdownTextBlock
                                    Text="{x:Bind Content, Mode=OneWay}"
                                    Background="Transparent"
                                    TextWrapping="Wrap"
                                    FontSize="14"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                    IsTextSelectionEnabled="True"
                                    Visibility="{x:Bind ShowAssistantText, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <Expander
                                    Visibility="{x:Bind IsTool, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Padding="0">
                                    <Expander.Header>
                                        <Grid Padding="0,8,4,8" ColumnSpacing="10" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="20" Height="20" VerticalAlignment="Center">
                                                <FontIcon
                                                    Glyph="&#xEC7A;"
                                                    FontSize="16"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                            </Grid>
                                            <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                                                <TextBlock
                                                    Text="Invoking"
                                                    FontSize="11"
                                                    LineHeight="12"
                                                    Opacity="0.72"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock
                                                    Text="{x:Bind Content, Mode=OneWay}"
                                                    FontFamily="{ThemeResource ContentControlThemeFontFamily}"
                                                    FontSize="13"
                                                    LineHeight="16"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                    TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Grid>
                                    </Expander.Header>
                                    <Expander.Content>
                                        <StackPanel Margin="12,8,12,12" Spacing="12">
                                            <StackPanel Spacing="6">
                                                <TextBlock
                                                    Text="输入"
                                                    FontSize="11"
                                                    Opacity="0.72"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <Border
                                                    Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10">
                                                    <ScrollViewer
                                                        MaxHeight="160"
                                                        HorizontalScrollMode="Auto"
                                                        HorizontalScrollBarVisibility="Auto"
                                                        VerticalScrollBarVisibility="Auto">
                                                        <TextBlock
                                                            Text="{x:Bind FormattedToolInputContent, Mode=OneWay}"
                                                            FontFamily="Consolas"
                                                            FontSize="12"
                                                            IsTextSelectionEnabled="True"
                                                            TextWrapping="NoWrap" />
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock
                                                    Text="输出"
                                                    FontSize="11"
                                                    Opacity="0.72"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <Border
                                                    Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10">
                                                    <ScrollViewer
                                                        MaxHeight="180"
                                                        HorizontalScrollMode="Auto"
                                                        HorizontalScrollBarVisibility="Auto"
                                                        VerticalScrollBarVisibility="Auto">
                                                        <TextBlock
                                                            Text="{x:Bind FormattedToolOutputContent, Mode=OneWay}"
                                                            FontFamily="Consolas"
                                                            FontSize="12"
                                                            IsTextSelectionEnabled="True"
                                                            TextWrapping="NoWrap" />
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander.Content>
                                </Expander>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel
                x:Name="EmptyStatePanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8"
                Visibility="Collapsed"
                IsHitTestVisible="False">
                <FontIcon Glyph="&#xE7FC;" FontSize="14" Foreground="{ThemeResource TextFillColorDisabledBrush}" />
                <TextBlock
                    Text="{Binding EmptyPlaceholderText, ElementName=Root}"
                    Foreground="{ThemeResource TextFillColorDisabledBrush}"
                    FontSize="14" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,16,0,0" Spacing="8">
            <Border
                Visibility="{Binding ViewModel.HasFixAction, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE946;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock
                                Text="待确认工具请求"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Opacity="0.78"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock
                            Text="{Binding ViewModel.FixButtonText, ElementName=Root}"
                            FontSize="18"
                            FontWeight="SemiBold"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <ScrollViewer
                        MaxHeight="240"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Text="{Binding ViewModel.CurrentFixActionSummary, ElementName=Root}"
                                TextWrapping="WrapWholeWords"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Visibility="{Binding ViewModel.ShouldShowCurrentFixActionSummary, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <ItemsControl
                                ItemsSource="{Binding ViewModel.CurrentFixActionChanges, ElementName=Root}"
                                Visibility="{Binding ViewModel.HasCurrentFixActionChanges, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:ActionProposalChangeItem">
                                        <Border
                                            Margin="0,0,0,8"
                                            Padding="12"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                            <StackPanel Spacing="8">
                                                <TextBlock
                                                    Text="{x:Bind DisplayName}"
                                                    FontWeight="SemiBold"
                                                    TextWrapping="WrapWholeWords" />
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="4" MaxWidth="420">
                                                        <TextBlock
                                                            Text="当前"
                                                            FontSize="11"
                                                            Opacity="0.72"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        <TextBlock
                                                            Text="{x:Bind OldValueDisplay}"
                                                            TextWrapping="WrapWholeWords" />
                                                    </StackPanel>
                                                    <FontIcon
                                                        Grid.Column="1"
                                                        Glyph="&#xE72A;"
                                                        FontSize="14"
                                                        Margin="2,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <StackPanel Grid.Column="2" Spacing="4">
                                                        <TextBlock
                                                            Text="目标"
                                                            FontSize="11"
                                                            Opacity="0.72"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        <TextBlock
                                                            Text="{x:Bind NewValueDisplay}"
                                                            TextWrapping="WrapWholeWords" />
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock
                                                    Text="{x:Bind Hint}"
                                                    FontSize="12"
                                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                    Visibility="{x:Bind HasHint, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock
                                Text="{Binding ViewModel.PendingProposalQueueText, ElementName=Root}"
                                FontSize="12"
                                Opacity="0.78"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="WrapWholeWords"
                                Visibility="{Binding ViewModel.HasPendingProposalQueueText, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </ScrollViewer>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="0"
                            Command="{Binding ViewModel.FixErrorCommand, ElementName=Root}"
                            IsEnabled="{Binding ViewModel.IsAIAnalyzing, ElementName=Root, Converter={StaticResource BoolNegationConverter}}"
                            HorizontalAlignment="Stretch"
                            Padding="12,8"
                            CornerRadius="4"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    Glyph="&#xE73E;"
                                    FontSize="16" />
                                <TextBlock
                                    Text="{Binding ViewModel.FixButtonText, ElementName=Root}"
                                    FontSize="14"
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="1"
                            IsEnabled="{Binding ViewModel.IsAIAnalyzing, ElementName=Root, Converter={StaticResource BoolNegationConverter}}"
                            Command="{Binding ViewModel.RejectFixActionCommand, ElementName=Root}"
                            Padding="12,8"
                            CornerRadius="4"
                            Style="{StaticResource DefaultButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE711;" FontSize="14" />
                                <TextBlock Text="拒绝" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
            <Button
                Command="{Binding ViewModel.FixErrorSecondaryCommand, ElementName=Root}"
                Visibility="{Binding ViewModel.HasSecondaryFixAction, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}"
                IsEnabled="{Binding ViewModel.IsAIAnalyzing, ElementName=Root, Converter={StaticResource BoolNegationConverter}}"
                HorizontalAlignment="Stretch"
                Padding="12,8"
                CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE74D;" FontSize="16" Margin="0,0,12,0" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding ViewModel.SecondaryFixButtonText, ElementName=Root}"
                        FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis"/>
                    <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="12" Opacity="0.8" />
                </Grid>
            </Button>
        </StackPanel>
        <ScrollViewer
            Grid.Row="2"
            Margin="0,12,0,0"
            HorizontalScrollMode="Auto"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollMode="Disabled"
            VerticalScrollBarVisibility="Disabled"
            Visibility="{Binding ViewModel.HasPendingChatAttachments, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding ViewModel.PendingImageAttachments, ElementName=Root}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ChatImageAttachment">
                        <StackPanel Width="120" Spacing="6">
                            <Grid Width="120" Height="92">
                                <Border
                                    Width="120"
                                    Height="92"
                                    Tag="{Binding}"
                                    Tapped="ChatImageCard_Tapped"
                                    PointerEntered="ChatImageCard_PointerEntered"
                                    PointerExited="ChatImageCard_PointerExited"
                                    PointerPressed="ChatImageCard_PointerPressed"
                                    PointerReleased="ChatImageCard_PointerReleased"
                                    PointerCanceled="ChatImageCard_PointerExited"
                                    PointerCaptureLost="ChatImageCard_PointerExited"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="{ThemeResource LayerFillColorAltBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Opacity="1">
                                    <Image
                                        Source="{Binding FilePath, Converter={StaticResource PathToImageSourceConverter}}"
                                        Stretch="UniformToFill" />
                                </Border>
                                <Button
                                    x:Uid="ErrorAnalysisChatPanel_RemovePendingImageButton"
                                    Width="24"
                                    Height="24"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,6,6,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding ViewModel.RemovePendingImageAttachmentCommand, ElementName=Root}"
                                    CommandParameter="{Binding}">
                                    <FontIcon Glyph="&#xE711;" FontSize="11" />
                                </Button>
                            </Grid>
                            <TextBlock
                                Text="{Binding FileName}"
                                TextWrapping="NoWrap"
                                TextTrimming="CharacterEllipsis"
                                FontSize="12" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="3" Margin="0,12,0,0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                x:Name="ChatInputBox"
                Text="{Binding ViewModel.ChatInput, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="Ask a follow-up question..."
                AcceptsReturn="True"
                TextWrapping="Wrap"
                MaxHeight="64"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                VerticalContentAlignment="Top"
                VerticalAlignment="Top"
                SizeChanged="ChatInputBox_SizeChanged"
                PreviewKeyDown="ChatInput_PreviewKeyDown"/>
            <Grid
                x:Name="ComposerButtonsPanel"
                Grid.Column="1"
                ColumnSpacing="8"
                VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    x:Name="AddImageButton"
                    x:Uid="ErrorAnalysisChatPanel_AddImageButton"
                    VerticalAlignment="Stretch"
                    Command="{Binding ViewModel.PickChatImagesCommand, ElementName=Root}"
                    Style="{StaticResource DefaultButtonStyle}">
                    <Grid Width="20" Height="20">
                        <FontIcon Glyph="&#xE91B;" FontSize="16" />
                    </Grid>
                </Button>
                <Button
                    Grid.Column="1"
                    x:Name="ChatActionButton"
                    VerticalAlignment="Stretch"
                    Command="{Binding ViewModel.CurrentChatActionCommand, ElementName=Root}"
                    Style="{StaticResource DefaultButtonStyle}">
                    <Grid Width="20" Height="20">
                        <FontIcon Glyph="{Binding ViewModel.CurrentChatActionGlyph, ElementName=Root}" FontSize="16" />
                    </Grid>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
