<UserControl
    x:Class="XianYuLauncher.Controls.LauncherAiPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:XianYuLauncher.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="Root">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,12" Visibility="{Binding HeaderVisibility, ElementName=Root}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE946;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock Text="{Binding SectionTitle, ElementName=Root}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
            <Button Grid.Column="1"
                    x:Uid="LauncherAiPanel_PopOutButton"
                    Click="PopOutButton_Click"
                    Visibility="{Binding PopOutButtonVisibility, ElementName=Root}"
                    Style="{StaticResource SubtleButtonStyle}"
                    Padding="6">
                <FontIcon Glyph="&#xE8A7;" FontSize="14" />
            </Button>
        </Grid>

        <Border Grid.Row="1"
            VerticalAlignment="Stretch"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:ErrorAnalysisChatPanel
                    Grid.RowSpan="3"
                    ViewModel="{Binding ViewModel, ElementName=Root}"
                    IsComposerEnabled="{Binding IsComposerEnabled, ElementName=Root}"
                    MessagesMaxHeight="{Binding MessagesMaxHeight, ElementName=Root}"
                    ShowEmptyPlaceholder="{Binding ShowEmptyPlaceholder, ElementName=Root}"
                    EmptyPlaceholderText="{Binding EmptyPlaceholderText, ElementName=Root}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>