<UserControl
    x:Class="XianYuLauncher.Controls.VersionIconPickerFlyoutContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:XianYuLauncher.Helpers"
    xmlns:models="using:XianYuLauncher.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <helpers:PathToImageSourceConverter x:Key="PathToImageSourceConverter" />
    </UserControl.Resources>

    <StackPanel Spacing="12" MinWidth="320" MaxWidth="400" Padding="16">
        <TextBlock Text="选择版本图标" Style="{StaticResource BaseTextBlockStyle}" />

        <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0" Padding="0,0,12,0">
            <ItemsControl ItemsSource="{x:Bind AvailableIcons, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapGrid Orientation="Horizontal" ItemWidth="52" ItemHeight="52" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:VersionIconOption">
                        <Button
                            Click="BuiltInIconButton_Click"
                            Tag="{x:Bind}"
                            Width="44"
                            Height="44"
                            Padding="6"
                            Margin="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="{x:Bind DisplayName}">
                            <Image
                                Source="{x:Bind IconPath, Converter={StaticResource PathToImageSourceConverter}}"
                                Stretch="UniformToFill" />
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-16,4" />

        <Button Click="CustomIconButton_Click" HorizontalAlignment="Stretch" Padding="12,8" Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE8E5;" FontSize="16" />
                <TextBlock Text="浏览自定义图标..." />
            </StackPanel>
        </Button>
    </StackPanel>
</UserControl>